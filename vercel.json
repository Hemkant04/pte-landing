{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "https://www.apenepal.com.np/$1"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "hemkant.com.np"
        }
      ],
      "destination": "https://www.apenepal.com.np/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "hemkant.com.np"
        }
      ],
      "destination": "https://www.apenepal.com.np/:path*",
      "permanent": true
    }
  ]
}